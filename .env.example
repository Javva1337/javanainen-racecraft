# E-post (kontaktformulär + nyhetsbrevs-fallback) — https://resend.com
# Utan nyckel faller kontaktformuläret tillbaka på en mailto-länk.
RESEND_API_KEY=

# Avsändaradress för Resend (verifierad domän), t.ex. "Rickard Javanainen <noreply@rickardjavanainen.se>"
RESEND_FROM=

# Nyhetsbrev — https://buttondown.com  (API-nyckel under Settings → API)
# Utan nyckel loggas/mailas adressen till dig via Resend i stället.
BUTTONDOWN_API_KEY=

# Publik bas-URL (sätts automatiskt av Vercel i produktion; behövs lokalt för OG-bilder)
NEXT_PUBLIC_SITE_URL=https://rickardjavanainen.se

# Publiceringssidan /admin — utan dessa svarar /api/admin/publicera med 503.
# Lösenordet väljer du själv; tokenen är en finkornig GitHub-PAT med
# contents:read/write på ENBART detta repo (github.com → Settings →
# Developer settings → Fine-grained tokens).
ADMIN_PASSWORD=
ADMIN_GITHUB_TOKEN=
# Valfria — repo defaultar till Javva1337/javanainen-racecraft. Branch
# defaultar till deployens egen branch (VERCEL_GIT_COMMIT_REF), annars main.
ADMIN_GITHUB_REPO=
ADMIN_GITHUB_BRANCH=
